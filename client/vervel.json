{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://nu-delivery-production.up.railway.app/api/$1"
    },
    {
      "src": "/auth/(.*)",
      "dest": "https://nu-delivery-production.up.railway.app/auth/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "https://nu-delivery-production.up.railway.app/uploads/$1"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "https://nu-delivery-production.up.railway.app/socket.io/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}