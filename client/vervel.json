{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://nu-delivery-production.up.railway.app/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://nu-delivery-production.up.railway.app/auth/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://nu-delivery-production.up.railway.app/uploads/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://nu-delivery-production.up.railway.app/socket.io/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}